{
  "$schema": "../../schemas/sdkwork-workflow.schema.json",
  "schemaVersion": "2026-06-06.sdkwork.workflow.v1",
  "app": {
    "id": "sdkwork-clawrouter",
    "name": "SDKWork Claw Router",
    "repository": "Sdkwork-Cloud/sdkwork-clawrouter",
    "sourcePath": "apps/sdkwork-clawrouter"
  },
  "release": {
    "artifactPrefix": "clawrouter",
    "defaultVersion": "0.3.0",
    "versionInput": "package_version",
    "tagInput": "tag",
    "changelog": {
      "source": "auto"
    }
  },
  "dependencies": [
    {
      "id": "sdkwork-appbase",
      "repository": "Sdkwork-Cloud/sdkwork-appbase",
      "refInput": "SDKWORK_APPBASE_REF",
      "path": "apps/sdkwork-appbase",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-core",
      "repository": "Sdkwork-Cloud/sdkwork-core",
      "refInput": "SDKWORK_CORE_REF",
      "path": "apps/sdkwork-core",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-ui",
      "repository": "Sdkwork-Cloud/sdkwork-ui",
      "refInput": "SDKWORK_UI_REF",
      "path": "apps/sdkwork-ui",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-im-sdk",
      "repository": "Sdkwork-Cloud/sdkwork-im-sdk",
      "refInput": "SDKWORK_IM_SDK_REF",
      "path": "apps/sdkwork-im/sdks/sdkwork-im-sdk",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    },
    {
      "id": "sdkwork-sdk-generator",
      "repository": "Sdkwork-Cloud/sdkwork-sdk-generator",
      "refInput": "SDKWORK_SDK_GENERATOR_REF",
      "path": "sdk/sdkwork-sdk-generator",
      "tokenSecret": "SDKWORK_RELEASE_TOKEN"
    }
  ],
  "toolchains": {
    "node": "22",
    "pnpm": "10.33.0",
    "python": "3.12",
    "rust": "stable",
    "wix": "5.0.2"
  },
  "lifecycle": {
    "install": [
      {
        "name": "Install portal workspace dependencies",
        "shell": "pwsh",
        "workingDirectory": "apps/sdkwork-clawrouter",
        "run": "pnpm --dir apps/sdkwork-clawrouter-pc install --frozen-lockfile"
      }
    ],
    "build": [
      {
        "name": "Build production artifacts",
        "shell": "pwsh",
        "workingDirectory": "apps/sdkwork-clawrouter",
        "run": "$downloadArgs = @(\"--version\", $env:SDKWORK_PACKAGE_VERSION, \"--release-tag\", $env:SDKWORK_RELEASE_TAG)\nif ($env:CLAWROUTER_DOWNLOAD_CDN_BASE_URL) {\n  $downloadArgs += @(\"--cdn-base-url\", $env:CLAWROUTER_DOWNLOAD_CDN_BASE_URL)\n}\nnode scripts/update-claw-router-downloads.mjs @downloadArgs\nnode scripts/build-claw-router-production.mjs\ncargo build -p sdkwork-claw-installer --bin clawrouterctl --release"
      }
    ],
    "stage": [
      {
        "name": "Stage production files",
        "shell": "pwsh",
        "workingDirectory": "apps/sdkwork-clawrouter",
        "run": "$ErrorActionPreference = \"Stop\"\n$stage = Join-Path (Get-Location) \"dist/install-package-staging\"\n$output = Join-Path (Get-Location) \"dist/install-packages\"\nRemove-Item -LiteralPath $stage -Recurse -Force -ErrorAction SilentlyContinue\nRemove-Item -LiteralPath $output -Recurse -Force -ErrorAction SilentlyContinue\nNew-Item -ItemType Directory -Force -Path (Join-Path $stage \"bin\") | Out-Null\nNew-Item -ItemType Directory -Force -Path (Join-Path $stage \"portal\") | Out-Null\n$suffix = if ($IsWindows) { \".exe\" } else { \"\" }\nCopy-Item -LiteralPath \"target/release/clawrouter$suffix\" -Destination (Join-Path $stage \"bin/clawrouter$suffix\")\nCopy-Item -LiteralPath \"target/release/clawrouterctl$suffix\" -Destination (Join-Path $stage \"bin/clawrouterctl$suffix\")\nCopy-Item -LiteralPath \".env.release.example\" -Destination (Join-Path $stage \".env.release.example\")\nCopy-Item -LiteralPath \"apps/sdkwork-clawrouter-pc/dist\" -Destination (Join-Path $stage \"portal/dist\") -Recurse"
      }
    ],
    "package": [
      {
        "name": "Build selected install package",
        "shell": "pwsh",
        "workingDirectory": "apps/sdkwork-clawrouter",
        "run": "$ErrorActionPreference = \"Stop\"\nif ($env:SDKWORK_PACKAGE_FORMAT -in @(\"deb\", \"rpm\", \"pkg\", \"msi\")) {\n  node scripts/build-claw-router-native-installer.mjs --package-id $env:SDKWORK_PACKAGE_ID --version $env:SDKWORK_PACKAGE_VERSION --staging-root dist/install-package-staging --output-dir dist/install-packages --json\n} else {\n  node scripts/build-claw-router-install-package.mjs --package-id $env:SDKWORK_PACKAGE_ID --version $env:SDKWORK_PACKAGE_VERSION --staging-root dist/install-package-staging --output-dir dist/install-packages --json\n}"
      }
    ],
    "validate": [
      {
        "name": "Validate selected install package",
        "shell": "pwsh",
        "workingDirectory": "apps/sdkwork-clawrouter",
        "run": "$ErrorActionPreference = \"Stop\"\n$file = Get-ChildItem -Path \"dist/install-packages\" -File |\n  Where-Object { $_.Name -like \"clawrouter-*$env:SDKWORK_PACKAGE_VERSION.*\" -and $_.Name -notlike \"*.manifest.json\" -and $_.Name -notlike \"install-packages-manifest*.json\" } |\n  Select-Object -First 1\nif (-not $file) { throw \"Missing built install package artifact for $env:SDKWORK_PACKAGE_ID\" }\nnode scripts/validate-claw-router-install-artifacts.mjs --package-id $env:SDKWORK_PACKAGE_ID --artifact-path $file.FullName --version $env:SDKWORK_PACKAGE_VERSION"
      }
    ],
    "sign": [
      {
        "name": "Sign artifacts placeholder",
        "shell": "pwsh",
        "workingDirectory": "apps/sdkwork-clawrouter",
        "run": "Write-Host \"Signing policy is configured at the application or environment level for $env:SDKWORK_PACKAGE_ID\""
      }
    ],
    "sbom": [
      {
        "name": "SBOM placeholder",
        "shell": "pwsh",
        "workingDirectory": "apps/sdkwork-clawrouter",
        "run": "Write-Host \"SBOM generation hook for $env:SDKWORK_PACKAGE_ID\""
      }
    ],
    "deploy": [
      {
        "name": "Deploy package placeholder",
        "shell": "pwsh",
        "workingDirectory": "apps/sdkwork-clawrouter",
        "run": "Write-Host \"Deploying $env:SDKWORK_PACKAGE_ID to $env:SDKWORK_DEPLOY_ENVIRONMENT at $env:SDKWORK_DEPLOY_URL\""
      }
    ],
    "publish": [
      {
        "name": "Publish package placeholder",
        "shell": "pwsh",
        "workingDirectory": "apps/sdkwork-clawrouter",
        "run": "Write-Host \"Publishing $env:SDKWORK_PACKAGE_ID through $env:SDKWORK_DEPLOY_ENVIRONMENT\""
      }
    ]
  },
  "targets": [
    {
      "id": "linux-debian-x64-standalone-server-deb",
      "profile": "server",
