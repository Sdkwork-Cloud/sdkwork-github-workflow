  "security": {
    "oidcRequired": true,
    "artifactAttestations": true,
    "sbomRequired": false,
    "signingRequired": false
  },
  "publish": {
    "workflowArtifact": true,
    "githubRelease": true,
    "retentionDays": 30
  },
  "deployments": [
    {
      "id": "production-server-linux",
      "environment": "production",
      "profile": "server",
      "platform": "linux",
      "format": "deb",
      "runner": "ubuntu-24.04",
      "url": "https://api.sdkwork.com/apps/sdkwork-clawrouter",
      "lifecycle": "deploy",
      "deploymentProfile": "standalone",
      "runtimeTarget": "server"
    },
