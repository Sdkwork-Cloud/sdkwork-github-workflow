{
  "$schema": "../../schemas/sdkwork-workflow.schema.json",
  "schemaVersion": "2026-06-06.sdkwork.workflow.v1",
  "app": {
    "id": "sdkwork-mobile-example",
    "name": "SDKWork Mobile Example",
    "repository": "Sdkwork-Cloud/sdkwork-mobile-example",
    "sourcePath": "."
  },
  "release": {
    "artifactPrefix": "sdkwork-mobile-example",
    "defaultVersion": "0.1.0",
    "changelog": {
      "source": "auto"
    }
  },
  "toolchains": {
    "java": "21",
    "flutter": "stable",
    "android": true,
    "xcode": true
  },
  "lifecycle": {
    "install": [
      {
        "run": "flutter pub get"
      }
    ],
    "build": [
      {
        "run": "flutter build $SDKWORK_PACKAGE_FORMAT --release"
      }
    ],
    "validate": [
      {
        "run": "test -n \"$SDKWORK_PACKAGE_ID\""
      }
    ],
    "sign": [
      {
        "run": "echo \"mobile signing hook for $SDKWORK_PACKAGE_ID\""
      }
    ],
    "publish": [
      {
        "run": "echo \"publish $SDKWORK_PACKAGE_ID to $SDKWORK_DEPLOY_ENVIRONMENT\""
      }
    ]
  },
  "targets": [
    {
      "id": "android-arm64-standalone-mobile-apk",
      "profile": "mobile",
      "platform": "android",
      "architecture": "arm64",
      "formats": [
        "apk"
      ],
      "runner": "ubuntu-24.04",
      "outputGlobs": [
        "build/app/outputs/flutter-apk/*.apk"
      ],
      "deploymentProfile": "standalone",
      "runtimeTarget": "flutter-android"
    },
    {
      "id": "android-arm64-standalone-mobile-aab",
      "profile": "mobile",
      "platform": "android",
      "architecture": "arm64",
      "formats": [
        "aab"
      ],
      "runner": "ubuntu-24.04",
      "outputGlobs": [
        "build/app/outputs/bundle/release/*.aab"
      ],
      "deploymentProfile": "standalone",
      "runtimeTarget": "flutter-android"
    },
    {
      "id": "ios-universal-standalone-mobile-ipa",
      "profile": "mobile",
      "platform": "ios",
      "architecture": "universal",
      "formats": [
        "ipa"
      ],
      "runner": "macos-14",
      "outputGlobs": [
        "build/ios/ipa/*.ipa"
      ],
      "deploymentProfile": "standalone",
      "runtimeTarget": "flutter-ios"
    }
  ],
  "security": {
    "oidcRequired": true,
    "artifactAttestations": true,
    "signingRequired": true
  },
  "publish": {
    "workflowArtifact": true,
    "githubRelease": true,
    "retentionDays": 30
  },
  "deployments": [
    {
      "id": "android-production",
      "environment": "production-mobile",
      "profile": "mobile",
      "platform": "android",
      "format": "aab",
      "runner": "ubuntu-24.04",
      "lifecycle": "publish",
      "deploymentProfile": "standalone"
    },
    {
      "id": "ios-production",
      "environment": "production-mobile",
      "profile": "mobile",
      "platform": "ios",
      "format": "ipa",
      "runner": "macos-14",
      "lifecycle": "publish",
      "deploymentProfile": "standalone"
    }
  ]
}
