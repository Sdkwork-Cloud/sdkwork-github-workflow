      "purpose": "Typed deployment and immutable artifact evidence integration."
    }
  ],
  "contracts": {
    "publicExports": ["."],
    "runtimeEntrypoints": ["sdkwork-workflow"],
    "routeManifest": null,
    "sdkClients": [],
    "events": [],
    "configKeys": ["sdkwork.workflow.json"]
  },
  "verification": {
