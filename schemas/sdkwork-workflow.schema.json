{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sdkwork.com/schemas/sdkwork-workflow.schema.json",
  "title": "SDKWork GitHub Workflow Configuration",
  "description": "Application-level configuration consumed by the SDKWork reusable GitHub Actions packaging workflow.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "app", "release", "targets"],
  "properties": {
    "schemaVersion": {
      "const": "2026-06-06.sdkwork.workflow.v1"
    },
    "app": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "repository"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "repository": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        },
        "sourcePath": {
          "type": "string",
          "minLength": 1
        },
        "configPath": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifactPrefix"],
      "properties": {
        "artifactPrefix": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$"
        },
        "defaultVersion": {
          "type": "string",
          "pattern": "^[0-9A-Za-z][0-9A-Za-z._+-]*$"
        },
        "versionInput": {
          "type": "string",
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
        },
        "tagInput": {
          "type": "string",
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
        },
        "channelInput": {
          "type": "string",
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
        }
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "repository"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]*$"
          },
          "repository": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
          },
          "ref": {
            "type": "string",
            "minLength": 1
          },
          "refInput": {
            "type": "string",
            "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "tokenSecret": {
            "type": "string",
            "pattern": "^[A-Z_][A-Z0-9_]*$"
          },
          "submodules": {
            "enum": [false, true, "false", "true", "recursive"]
          }
        }
      }
    },
    "toolchains": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "node": {
          "type": "string"
        },
        "pnpm": {
          "type": "string"
        },
        "python": {
          "type": "string"
        },
        "java": {
          "type": "string"
        },
        "go": {
          "type": "string"
        },
        "rust": {
          "type": "string"
        },
        "flutter": {
          "type": "string"
        },
        "dotnet": {
          "type": "string"
        },
        "android": {
          "type": "boolean"
        },
        "xcode": {
          "type": "boolean"
        },
        "wix": {
          "type": "string"
        }
      }
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "preflight": {
          "$ref": "#/$defs/steps"
        },
        "install": {
          "$ref": "#/$defs/steps"
        },
        "build": {
          "$ref": "#/$defs/steps"
        },
        "stage": {
          "$ref": "#/$defs/steps"
        },
        "package": {
          "$ref": "#/$defs/steps"
        },
        "sign": {
          "$ref": "#/$defs/steps"
        },
        "sbom": {
          "$ref": "#/$defs/steps"
        },
        "validate": {
          "$ref": "#/$defs/steps"
        },
        "deploy": {
          "$ref": "#/$defs/steps"
        },
        "publish": {
          "$ref": "#/$defs/steps"
        }
      }
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "profile", "platform", "architecture", "formats", "runner", "outputGlobs"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]*$"
          },
          "packageId": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]*$"
          },
          "profile": {
            "enum": ["server", "desktop", "mobile", "tablet", "web", "worker", "library"]
          },
          "platform": {
            "enum": ["linux", "windows", "macos", "ios", "ipados", "android", "android-tablet", "windows-tablet", "web", "container"]
          },
          "architecture": {
            "enum": ["x64", "arm64", "armv7", "universal", "wasm32", "noarch"]
          },
          "formats": {
            "type": "array",
            "minItems": 1,
            "items": {
              "enum": [
                "zip",
                "tar.gz",
                "deb",
                "rpm",
                "pkg",
                "dmg",
                "msi",
                "msix",
                "exe",
                "appimage",
                "snap",
                "flatpak",
                "docker",
                "oci",
                "helm",
                "apk",
                "aab",
                "ipa",
                "web",
                "static",
                "jar",
                "war"
              ]
            },
            "uniqueItems": true
          },
          "runner": {
            "type": "string",
            "minLength": 1
          },
          "outputGlobs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "environment": {
            "type": "string"
          },
          "signing": {
            "type": "boolean"
          }
        }
      }
    },
    "security": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "oidcRequired": {
          "type": "boolean"
        },
        "artifactAttestations": {
          "type": "boolean"
        },
        "sbomRequired": {
          "type": "boolean"
        },
        "signingRequired": {
          "type": "boolean"
        }
      }
    },
    "publish": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "workflowArtifact": {
          "type": "boolean"
        },
        "githubRelease": {
          "type": "boolean"
        },
        "retentionDays": {
          "type": "integer",
          "minimum": 1,
          "maximum": 90
        }
      }
    },
    "deployments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "environment"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]*$"
          },
          "environment": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
          },
          "url": {
            "type": "string"
          },
          "runner": {
            "type": "string"
          },
          "profile": {
            "enum": ["server", "desktop", "mobile", "tablet", "web", "worker", "library"]
          },
          "platform": {
            "enum": ["linux", "windows", "macos", "ios", "ipados", "android", "android-tablet", "windows-tablet", "web", "container"]
          },
          "architecture": {
            "enum": ["x64", "arm64", "armv7", "universal", "wasm32", "noarch"]
          },
          "format": {
            "enum": [
              "zip",
              "tar.gz",
              "deb",
              "rpm",
              "pkg",
              "dmg",
              "msi",
              "msix",
              "exe",
              "appimage",
              "snap",
              "flatpak",
              "docker",
              "oci",
              "helm",
              "apk",
              "aab",
              "ipa",
              "web",
              "static",
              "jar",
              "war"
            ]
          },
          "targetId": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]*$"
          },
          "packageId": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]*$"
          },
          "lifecycle": {
            "enum": ["deploy", "publish"]
          }
        }
      }
    }
  },
  "$defs": {
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["run"],
        "properties": {
          "name": {
            "type": "string"
          },
          "run": {
            "type": "string"
          },
          "shell": {
            "enum": ["bash", "pwsh", "powershell", "sh", "cmd", "node"]
          },
          "workingDirectory": {
            "type": "string"
          },
          "env": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
